<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= user.name %></p>
    <p>Username: <%= user.email %></p>
    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">Registered Users List</a></p>
    <% } %>
    <% if (volunteeredProjects.length > 0) { %>
        <h2>Volunteered Projects</h2>
        <table>
        <% volunteeredProjects.forEach(volunteeredProject => { %>
            <tr>
                <td><a href="/project/<%= volunteeredProject.project_id %>"><%= volunteeredProject.title %></a></td>
                <td class="action-cell">
                    <form class="leaveProject" action="/process-unregistration" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to leave this project?');">
                        <input type="hidden" name="project_id" value="<%= volunteeredProject.project_id %>">

                        <button type="submit" class="category-tag" style="background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; cursor: pointer;">
                            Leave Project
                        </button>
                    </form>
                </td>
            </tr>
        <% }); %>
        </table>
    <% } %>
</main>

<%- include('partials/footer') %>