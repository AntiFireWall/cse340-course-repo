<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p>Here are a few of our partner organizations:</p>
        <ul>
            <% organizations.forEach(organization => { %>
                <li><a href="/organization/<%= organization.organization_id %>"><img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><strong><%= organization.name %></strong>: <%= organization.contact_email %></a></li>
            <% }); %>
        </ul>
    </main>
<%- include('partials/footer') %>