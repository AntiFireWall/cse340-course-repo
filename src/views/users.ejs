<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <table>
        <tr>
          <th>Name</th>
          <th>Email(Username)</th>
          <th>Role</th>
        </tr>
        <% usersListDetails.forEach(userDetails => { %>
            <tr>
                <td><%= userDetails.name %></td>
                <td><%= userDetails.email %></td>
                <td><%= userDetails.role_name %></td>
            </tr>
        <% }); %>
    </table>

</main>
<%- include('partials/footer') %>